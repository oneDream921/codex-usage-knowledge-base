#!/bin/sh

echo "Running pre-commit checks..."

git diff --check || exit 1

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/check-sensitive.ps1 -StagedOnly
elif command -v powershell.exe >/dev/null 2>&1; then
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/check-sensitive.ps1 -StagedOnly
elif command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-sensitive.ps1 -StagedOnly
else
  echo "PowerShell is required to run scripts/check-sensitive.ps1" >&2
  exit 1
fi
